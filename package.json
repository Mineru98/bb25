{
  "name": "bb25-ts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript port of bb25 (Bayesian BM25). Monorepo root.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
